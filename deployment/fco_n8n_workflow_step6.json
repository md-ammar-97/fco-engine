        0,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst boolYesNo = (v) => String(v || '').trim().toLowerCase() === 'yes';\nconst toNum = (v, fallback = 0) => {\n  const n = Number(v);\n  return Number.isFinite(n) ? n : fallback;\n};\n\nconst item = $input.first();\nconst j = item.json;\n\nreturn [{\n  json: {\n    ...j,\n    Publish_To_Google_Sheets_Bool: boolYesNo(j.Publish_To_Google_Sheets),\n    Force_Rerun_Bool: boolYesNo(j.Force_Rerun),\n    Assumed_MPG_Num: toNum(j.Assumed_MPG, 5),\n    Starting_Fuel_1_Num: toNum(j.Starting_Fuel_1, 100),\n    Starting_Fuel_2_Num: toNum(j.Starting_Fuel_2, 150),\n    Starting_Fuel_3_Num: toNum(j.Starting_Fuel_3, 180),\n    Ending_Fuel_Reserve_Num: toNum(j.Ending_Fuel_Reserve, 40),\n    Tank_Capacity_Num: toNum(j.Tank_Capacity, 240),\n    Route_Cluster_Radius_Miles_Num: toNum(j.Route_Cluster_Radius_Miles, 50),\n    Corridor_Radius_Miles_Num: toNum(j.Corridor_Radius_Miles, 15),\n    Rough_Cost_Decision_Threshold_Num: toNum(j.Rough_Cost_Decision_Threshold, 5000),\n    Current_CPG_Override_Num: toNum(j.Current_CPG_Override, 0),\n  },\n  binary: item.binary\n}];\n"
      },
      "id": "19bbdc36-4a49-41a4-9fec-d0a975a1630c",
      "name": "Normalize Inputs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "\nfunction slugify(s) {\n  return String(s || 'client')\n    .trim()\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '') || 'client';\n}\n\nfunction rand(len = 32) {\n  const chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';\n  let out = '';\n  for (let i = 0; i < len; i++) out += chars[Math.floor(Math.random() * chars.length)];\n  return out;\n}\n\nconst item = $input.first();\nconst j = item.json;\nconst now = new Date();\nconst stamp = now.toISOString().replace(/[-:.TZ]/g, '').slice(0, 14);\nconst baseShared = $env.FCO_SHARED_CONTAINER_PATH || '/shared/fco';\nconst runId = `fco_${slugify(j.Client_Full_Name)}_${stamp}`;\nconst callbackToken = rand(32);\n\nconst runRoot = `${baseShared}/runs/${runId}`;\nconst inputDir = `${runRoot}/input`;\nconst outputDir = `${runRoot}/output`;\nconst logsDir = `${runRoot}/logs`;\nconst stateDir = `${runRoot}/state`;\n\nreturn [{\n  json: {\n    ...j,\n    run_id: runId,\n    callback_token: callbackToken,\n    run_root: runRoot,\n    input_dir: inputDir,\n    output_dir: outputDir,\n    logs_dir: logsDir,\n    state_dir: stateDir,\n    callback_url: `${$env.N8N_HOST_PROTOCOL || 'http'}://${$env.N8N_HOST || 'localhost'}:${$env.N8N_PORT || '5678'}/webhook/fco-callback/${runId}`\n  },\n  binary: item.binary\n}];\n"
      },
      "id": "c2413f86-a3f8-4ccc-93a5-cb304501f70f",
      "name": "Generate Run Context",
