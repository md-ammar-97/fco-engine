      "id": "d515d90a-f63c-4592-a6fd-7a08783ace8d",
      "name": "Wait for FCO Callback",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        2100,
        280
      ],
      "notes": "Configure this Wait node to resume by webhook after import. Use the generated resume/callback URL in the job payload if you prefer native wait URLs over the deterministic callback URL scaffold."
    },
    {
      "parameters": {
        "jsCode": "\nconst item = $input.first();\nconst body = item.json;\nconst headers = body.headers || {};\nconst expectedToken = $('Generate Run Context').first().json.callback_token;\nconst expectedRunId = $('Generate Run Context').first().json.run_id;\n\nconst receivedToken =\n  headers['x-fco-callback-token'] ||\n  headers['X-FCO-Callback-Token'] ||\n  '';\n\nconst valid = String(body.run_id || '') === String(expectedRunId)\n  && String(receivedToken || '') === String(expectedToken);\n\nreturn [{\n  json: {\n    valid_callback: valid,\n    callback_body: body,\n    expected_run_id: expectedRunId,\n    callback_success: Boolean(body.success)\n  }\n}];\n"
      },
      "id": "4467691c-e97b-4bbe-a75c-54d06486804d",
      "name": "Validate Callback",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2360,
        180
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.valid_callback}}",
              "value2": true
            }
          ]
        }
      },
      "id": "5d1fcf27-ab80-4b10-9d24-6efcbeeee1a4",
      "name": "If Callback Valid",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2620,
        180
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.callback_success}}",
              "value2": true
            }
          ]
        }
      },
      "id": "35a5d83b-6873-468d-9e98-f7dfe28cfe75",
      "name": "If Callback Success",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2880,
        120
      ]
