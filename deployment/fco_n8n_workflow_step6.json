        "url": "={{$env.FCO_API_BASE_URL + '/runs/' + $('Generate Run Context').first().json.run_id + '/manifest'}}",
        "options": {}
      },
      "id": "4f3e08b9-eacb-4fd7-86d2-6f5037a9e3ab",
      "name": "Get Manifest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2880,
        420
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst m = $input.first().json.manifest || $input.first().json.callback_body || $input.first().json;\n\nreturn [{\n  json: {\n    success: true,\n    run_id: m.run_id,\n    message: 'FCO run completed successfully.',\n    workbook_download_url: `${$env.FCO_API_BASE_URL}/runs/${m.run_id}/download/workbook`,\n    pdf_download_url: `${$env.FCO_API_BASE_URL}/runs/${m.run_id}/download/pdf`,\n    google_sheet_url: m.google_sheet_url || '',\n    summary: m.summary || {}\n  }\n}];\n"
      },
      "id": "9fecaaca-6406-413a-af03-1b6069086aff",
      "name": "Build Success Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3140,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst j = $input.first().json;\nreturn [{\n  json: {\n    success: false,\n    run_id: j.run_id || $('Generate Run Context').first().json.run_id,\n    message: j.error || j.error_message || 'FCO run failed.',\n    details: j\n  }\n}];\n"
      },
      "id": "b9e2263a-c027-4c88-8088-0131f1340080",
      "name": "Build Failure Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3140,
        500
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}",
        "options": {}
      },
      "id": "0a0b48e4-2112-490f-8fd2-c6d01253b0de",
      "name": "Form Completion",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        3400,
        340
      ]
    }
